// Treasure Hunt — relational schema (replaces Firestore collections).
// Only the Next.js server touches this DB; clients never connect directly.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum ChallengeType {
  PICTURE
  RIDDLE
}

enum NotificationType {
  info
  warning
  success
  error
}

// A login account. Team leaders are USER; the single admin is ADMIN.
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         Role     @default(USER)
  // Bumped to invalidate all existing JWTs (logout-all / forced revocation).
  tokenVersion Int      @default(0)
  createdAt    DateTime @default(now())

  team          Team?
  gameState     GameState?
  notifications Notification[]     @relation("NotificationAuthor")
  reads         NotificationRead[]

  @@index([role])
}

model Team {
  id               String       @id @default(cuid())
  userId           String       @unique
  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  teamName         String
  leaderName       String
  leaderMobile     String
  leaderDepartment String
  createdAt        DateTime     @default(now())
  members          TeamMember[]
}

model TeamMember {
  id         String @id @default(cuid())
  teamId     String
  team       Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  name       String
  mobile     String
  department String
}

// An admin-managed, named collection of challenges.
model Dataset {
  id         String      @id @default(cuid())
  name       String      @unique
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  challenges Challenge[]
  gameStates GameState[]
  selectedBy GameSettings[]
}

// Per-user game progress. Score/progress are written only by the server.
model GameState {
  id              String    @id @default(cuid())
  userId          String    @unique
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Dataset is frozen at game creation so an admin switch never corrupts a game in
  // progress. Restrict delete so a dataset a game has used can't be removed.
  datasetId       String
  dataset         Dataset   @relation(fields: [datasetId], references: [id], onDelete: Restrict)
  // Frozen shuffled snapshot of the dataset's challenge ids (length = this game's total).
  challengeIds    String[]
  currentIndex    Int       @default(0)
  score           Int       @default(0)
  skipsUsed       Int       @default(0)
  cooldownEndsAt  DateTime?
  startedAt       DateTime  @default(now())
  lastCompletedAt DateTime?
  lastActivityAt  DateTime  @default(now())
  isComplete      Boolean   @default(false)

  completions Completion[]
  skips       Skip[]
  submissions Submission[]

  @@index([score, lastCompletedAt])
}

// A successfully solved challenge (true completions, separate from skips).
model Completion {
  id            String    @id @default(cuid())
  gameStateId   String
  gameState     GameState @relation(fields: [gameStateId], references: [id], onDelete: Cascade)
  challengeId   String
  pointsAwarded Int
  completedAt   DateTime  @default(now())

  @@unique([gameStateId, challengeId])
}

// A skipped challenge (consumes the slot but is not a completion).
model Skip {
  id          String    @id @default(cuid())
  gameStateId String
  gameState   GameState @relation(fields: [gameStateId], references: [id], onDelete: Cascade)
  challengeId String
  penalty     Int
  skippedAt   DateTime  @default(now())

  @@unique([gameStateId, challengeId])
}

// Audit trail of every verification attempt (anti-cheat / forensics).
model Submission {
  id          String    @id @default(cuid())
  gameStateId String
  gameState   GameState @relation(fields: [gameStateId], references: [id], onDelete: Cascade)
  challengeId String
  latitude    Float
  longitude   Float
  accuracy    Float?
  distance    Float
  success     Boolean
  createdAt   DateTime  @default(now())

  @@index([gameStateId, createdAt])
}

// A challenge belonging to a dataset. Coordinates live here and are NEVER sent to the client.
model Challenge {
  id            String        @id @default(cuid())
  datasetId     String
  dataset       Dataset       @relation(fields: [datasetId], references: [id], onDelete: Cascade)
  position      Int
  type          ChallengeType
  title         String
  description   String
  imageUrl      String?
  latitude      Float
  longitude     Float
  marginOfError Int
  points        Int

  @@unique([datasetId, position])
}

// Single global settings row (id = "global").
model GameSettings {
  id              String   @id @default("global")
  startTime       DateTime
  durationMs      Int
  isPaused        Boolean  @default(false)
  pausedAt        DateTime?
  totalPauseMs    Int      @default(0)
  isActive        Boolean  @default(true)
  // The dataset new registrations will use (null until the admin picks one).
  selectedDatasetId String?
  selectedDataset   Dataset? @relation(fields: [selectedDatasetId], references: [id], onDelete: SetNull)
  maxTeamSize     Int      @default(4)
  minTeamSize     Int      @default(3)
  // Admin-tunable gameplay rules (applied live).
  skipPenalty     Int      @default(5)
  cooldownMs      Int      @default(60000)
  maxSkips        Int      @default(3)
  updatedAt       DateTime @updatedAt
}

model Notification {
  id          String           @id @default(cuid())
  title       String
  message     String
  type        NotificationType @default(info)
  isActive    Boolean          @default(true)
  createdById String?
  createdBy   User?            @relation("NotificationAuthor", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime         @default(now())

  reads NotificationRead[]

  @@index([isActive, createdAt])
}

// Replaces the readBy[] array — a row per (notification, user) dismissal.
model NotificationRead {
  id             String       @id @default(cuid())
  notificationId String
  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  readAt         DateTime     @default(now())

  @@unique([notificationId, userId])
}

// A frozen snapshot of a finished/stopped game: its config + full final
// standings (one self-contained record that survives team resets). `data`
// holds the per-team results array (see lib/archive.ts).
model GameArchive {
  id            String   @id @default(cuid())
  label         String
  datasetName   String
  startTime     DateTime
  durationMs    Int
  teamCount     Int
  topScore      Int
  finishedCount Int      @default(0)
  archivedAt    DateTime @default(now())
  data          Json

  @@index([archivedAt])
}
