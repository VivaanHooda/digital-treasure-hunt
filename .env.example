# ---------------------------------------------------------------------------
# SERVER-ONLY configuration. NONE of these are exposed to the browser.
# Never prefix secrets with NEXT_PUBLIC_. Copy to .env and fill real values.
# ---------------------------------------------------------------------------

# PostgreSQL (matches docker-compose.yml; host port 5433 avoids native Postgres on 5432)
DATABASE_URL="postgresql://treasure:treasure_dev_password@localhost:5433/treasure_hunt?schema=public"

# Redis (matches docker-compose.yml)
REDIS_URL="redis://localhost:6379"

# Auth.js / NextAuth — generate with: openssl rand -base64 32
AUTH_SECRET="replace_me_with_a_long_random_string"
# Base URL of the app (used by Auth.js)
AUTH_URL="http://localhost:3000"

# Admin account — used ONLY at seed time to create the ADMIN user (hashed).
# Rotate the value that leaked in git history.
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change_me_strong_password"

# Game tuning (optional; defaults applied if unset)
GAME_DEFAULT_DURATION_MS="7200000"
COOLDOWN_MS="60000"
SKIP_PENALTY="5"
MAX_SKIPS="3"
